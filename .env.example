# ============================================================================
# Flux Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ============================================================================

# Core
FLUX_ENV=development
FLUX_MASTER_KEY=          # Fernet key: run `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`

# Database (SQLite paths)
# On Termux internal storage:
DATABASE_URL=sqlite:///~/flux/app.db
# Local Quran text DB (for Whisper fuzzy matching):
QURAN_TEXT_DB_URL=sqlite:///~/flux/quran_text.db

# Storage
# Internal path (must support file locking):
BASE_PATH=~/flux
# Shared storage path (for large media):
STORAGE_PATH=/storage/emulated/0/Flux
STORAGE_BUDGET_GB=5

# Telegram notifications
TELEGRAM_BOT_TOKEN=       # From @BotFather
TELEGRAM_CHAT_ID=         # Your personal chat ID

# GitHub Actions remote trigger security
FLUX_REMOTE_KEY=          # Random secret for /api/system/remote bearer token

# Cloudflare Tunnel public URL (for GH Actions watchdog reachability)
# Only needed in production / on Termux
FLUX_PUBLIC_URL=          # e.g., https://flux-phone.yourdomain.trycloudflare.com

# YouTube Data API v3
YOUTUBE_CLIENT_SECRETS_PATH=~/flux/secrets/youtube_client_secret.json

# Pexels / Unsplash
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
